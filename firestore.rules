rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Common helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // User Profile
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      // allow read (get/list) for the server-side API (unauthenticated query)
      // and for authenticated users to see their own profile
      allow read: if request.auth == null || (isSignedIn() && (resource.data.id == request.auth.uid || isAdmin()));
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['name', 'email', 'role', 'plan', 'createdAt']) &&
        request.resource.data.role == 'user' &&
        request.resource.data.plan == 'free';
      allow update: if (isAdmin()) || (isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'apiKey', 'apiSecret', 'status', 'webhookUrl', 'plan', 'balance', 'lastLogin']) &&
        request.resource.data.role == resource.data.role); // Prevent changing role
    }

    // Devices
    match /devices/{deviceId} {
      // Allow server-side read/write (unauthenticated)
      allow read, create, update: if request.auth == null || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Transactions
    match /transactions/{transactionId} {
      // Allow server-side read/create (unauthenticated)
      allow read, create: if request.auth == null || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Subscriptions - Read-only for users
    match /subscriptions/{subId} {
      allow list, get: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // Deposit Requests
    match /depositRequests/{requestId} {
      allow list, get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      // Creation usually via API, but allow client for dashboard testing
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // User Deposits
    match /userDeposits/{depositId} {
      allow list, get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // System Config
    match /system/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Plans
    match /plans/{planId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
